<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>C-GATE PORTAL</title>
    
    @* EXTERNAL ASSETS: Bootstrap for layout, Icons for UI, and Animate.css for feedback *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    <style>
        :root { --primary-blue: #0d6efd; }
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar-brand { font-weight: 800; letter-spacing: 1px; color: var(--primary-blue) !important; }
        .text-uppercase-forced { text-transform: uppercase; }
        .text-data-bold { font-weight: 700; color: #212529; }
        
        /* LOGIC: Custom styling for class schedule info box */
        .grace-period-box { background-color: #e7f1ff; border-radius: 10px; padding: 10px; border: 1px solid #cfe2ff; }
        .text-blue-custom { color: #084298; }
    </style>
</head>

@* THEME: 'min-vh-100' and 'd-flex flex-column' ensures the footer never floats in the middle of the screen *@
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white shadow-sm mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand animate__animated animate__fadeInLeft" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-door-open-fill"></i> C-GATE PORTAL
                </a>
                
                @* BRANDING: Identifies the institution and current academic period *@
                <div class="ms-auto text-end d-none d-md-block">
                    <span class="school-tag fw-bold text-uppercase d-block small">CEC IT DEPARTMENT</span>
                    <span class="badge bg-light text-primary border" style="font-size: 0.65rem;">2ND SEMESTER SY 2025-2026</span>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4 flex-grow-1">
        <main role="main" class="pb-5">
            @* GLOBAL ALERT: Used to display system-wide maintenance messages *@
            @if (TempData["ShowMaintenance"] != null)
            {
                <div class="alert alert-dark border-0 shadow-sm text-center animate__animated animate__fadeInDown">
                    <i class="bi bi-gear-fill me-2"></i>
                    <span class="fw-bold text-uppercase">@TempData["ShowMaintenance"]</span>
                </div>
            }

            @* DYNAMIC CONTENT: This is where Login, Index, and Register views are injected *@
            @RenderBody()
        </main>
    </div>

    @* FOOTER: Professional sign-off including the year and school name *@
    <footer class="footer text-muted py-3 mt-auto bg-white border-top shadow-sm">
        <div class="container-fluid px-4 text-center">
            <div class="row">
                <div class="col-md-6 text-md-start">
                    <span class="small fw-bold">&copy; 2026 - C-Gate Attendance System</span>
                </div>
                <div class="col-md-6 text-md-end">
                    <span class="small text-uppercase fw-bold text-primary">Cebu Eastern College</span>
                </div>
            </div>
        </div>
    </footer>

    @* SCRIPTS: Standard JS libraries for Bootstrap functionality *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @* CRITICAL: Renders custom scripts from individual views (like validation logic) *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>